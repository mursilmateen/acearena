# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/acearedb?retryWrites=true&w=majority
# Optional alias used by some hosts (Railway/Render templates)
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/acearedb?retryWrites=true&w=majority
# Additional aliases used by some managed Mongo integrations
# MONGO_URL=mongodb://...
# MONGODB_URL=mongodb://...

# JWT Configuration
JWT_SECRET=your_very_secret_jwt_key_here_change_in_production
JWT_EXPIRY=15m

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional single-variable Cloudinary config
# CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL(s) for CORS
# Local development
FRONTEND_URL=http://localhost:3000

# Production domains (optional)
# FRONTEND_URLS=https://acearena.com,https://www.acearena.com

# Legacy variable (optional, still supported)
# CORS_ORIGIN=http://localhost:3000

# File Upload
MAX_FILE_SIZE=104857600
UPLOAD_DIR=uploads

# Optional: Log Level
LOG_LEVEL=info
