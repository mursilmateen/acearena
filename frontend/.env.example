# Frontend Environment Configuration
# Copy this file to .env.local and fill in your actual values

# API Configuration
NEXT_PUBLIC_API_URL=https://api.acearena.com

# Launch controls
# true  -> show only configured live game titles in public listings
# false -> show all games
NEXT_PUBLIC_LAUNCH_MODE_ENABLED=true

# true  -> game upload route and entry points display Coming Soon
# false -> game upload is available
NEXT_PUBLIC_GAME_UPLOAD_COMING_SOON=true

# Comma-separated game titles used when launch mode is enabled
NEXT_PUBLIC_LIVE_GAME_TITLES=Falling Crown,Space Run

# Optional: Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Optional: Social Media
NEXT_PUBLIC_DISCORD_INVITE_URL=
NEXT_PUBLIC_TWITTER_URL=
